{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".env",
      ".git/**",
      ".gitignore",
      "node_modules/**",
      "scripts/**",
      "tests/**",
      "engine/**",
      "explainer/**",
      "knowledge/**",
      "data/**",
      "stockfish/**",
      "*.py",
      "*.md",
      "requirements.txt",
      "__pycache__/**",
      ".claude/**"
    ],
    "headers": [
      {
        "source": "**/*.wasm",
        "headers": [
          { "key": "Content-Type", "value": "application/wasm" }
        ]
      },
      {
        "source": "static/lib/stockfish/**",
        "headers": [
          { "key": "Cross-Origin-Embedder-Policy", "value": "require-corp" },
          { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
